{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlyriaCloud",
  "version": "0.1.0",
  "identifier": "app.glyria.cloud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Glyria Cloud - Internal App",
        "width": 1400,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/logo.png",
      "icons/logo.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4QjUyNkEwOUJEQUJDNDYKUldSR3ZOcWJvQ2ExK0gxWHdMSVBOYUxFeGhHdzdld1JVWEVKdlE3M2VFaFVRc3RYQTRDMG1reHMK",
      "endpoints": [
        "https://github.com/Kiki344r/GlyriaCloudApp/releases/latest/download/updater.json"
      ]
    }
  }
}
